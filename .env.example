# e-КТРМ MVP environment template
# Copy to .env and adjust values for local/dev deployment.

# ---------- General ----------
APP_ENV=local
LOG_LEVEL=INFO
TZ=Asia/Qyzylorda

# ---------- Gateway / URLs ----------
PUBLIC_BASE_URL=http://localhost:8080
GATEWAY_PORT=8080
FRONTEND_PORT=4200
APPLICATIONS_PORT=8081
CERTIFICATES_PORT=8082
REFERENCE_DATA_PORT=8083
FILES_PORT=8084
NOTIFICATIONS_PORT=8085

# ---------- PostgreSQL ----------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_EXPOSE_PORT=5432
POSTGRES_DB=ektrm
POSTGRES_USER=ektrm
POSTGRES_PASSWORD=change_me

# ---------- Redis / Celery ----------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_EXPOSE_PORT=6379
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ---------- MinIO ----------
MINIO_ENDPOINT=minio:9000
MINIO_EXPOSE_PORT=9000
MINIO_CONSOLE_EXPOSE_PORT=9001
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_FILES=ektrm-files
MINIO_BUCKET_PDF=ektrm-pdf
MINIO_SECURE=false

# ---------- Keycloak ----------
KEYCLOAK_URL=http://keycloak:8080
KEYCLOAK_EXPOSE_PORT=8088
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=change_me
KEYCLOAK_REALM=ektrm
KEYCLOAK_CLIENT_ID=ektrm-web
KEYCLOAK_AUDIENCE=ektrm-api
KEYCLOAK_ISSUER=http://localhost:8088/realms/ektrm
KEYCLOAK_JWKS_URL=http://localhost:8088/realms/ektrm/protocol/openid-connect/certs
KEYCLOAK_LOGOUT_URL=http://localhost:8088/realms/ektrm/protocol/openid-connect/logout

# ---------- OIDC Frontend ----------
OIDC_AUTHORITY=http://localhost:8088/realms/ektrm
OIDC_CLIENT_ID=ektrm-web
OIDC_REDIRECT_URI=http://localhost:4200/auth/callback
OIDC_POST_LOGOUT_REDIRECT_URI=http://localhost:4200
OIDC_SILENT_REDIRECT_URI=http://localhost:4200/auth/silent-callback

# ---------- Feature flags ----------
FEATURE_RESUME_CERTIFICATE=false
FEATURE_PUBLIC_REGISTRY=true
